name: React Native Android Build

on:
  push:
    branches: [ "main", "master" ]
  pull_request:
    branches: [ "main", "master" ]

jobs:
  build-android:
    runs-on: ubuntu-latest

    steps:
      # 1. Checkout kode sumber
      - name: Checkout code
        uses: actions/checkout@v4

      # 2. Setup Node.js (Sesuaikan versi dengan proyek Anda, biasanya 18 atau 20)
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '18'
          cache: 'npm' # Atau 'yarn' jika Anda menggunakan Yarn

      # 3. Install Dependensi JavaScript
      - name: Install npm dependencies
        run: npm ci # Gunakan 'npm install' jika tidak ada package-lock.json

      # 4. Setup Java JDK 17 (Wajib untuk React Native versi baru & Android Gradle Plugin terbaru)
      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          java-version: '17'
          distribution: 'temurin'

      # 5. Grant permission untuk gradlew di folder android
      - name: Grant execute permission for gradlew
        run: chmod +x android/gradlew

      # 6. Cache Gradle untuk mempercepat build berikutnya
      - name: Cache Gradle
        uses: actions/cache@v4
        with:
          path: |
            ~/.gradle/caches
            ~/.gradle/wrapper
          key: ${{ runner.os }}-gradle-${{ hashFiles('android/**/*.gradle*', 'android/gradle/wrapper/gradle-wrapper.properties') }}
          restore-keys: |
            ${{ runner.os }}-gradle-

      # 7. Build APK (Debug & Release)
      # Catatan: Untuk Release APK yang signed, Anda perlu konfigurasi signing tambahan.
      # Ini akan menghasilkan APK unsigned atau debug-signed.
      - name: Build Android APK
        working-directory: ./android
        run: ./gradlew assembleDebug assembleRelease

      # 8. Upload APK Debug sebagai Artifact
      - name: Upload Debug APK
        uses: actions/upload-artifact@v4
        with:
          name: react-native-app-debug
          path: android/app/build/outputs/apk/debug/app-debug.apk
          retention-days: 7

      # 9. Upload APK Release sebagai Artifact
      - name: Upload Release APK
        uses: actions/upload-artifact@v4
        with:
          name: react-native-app-release
          path: android/app/build/outputs/apk/release/app-release.apk
          retention-days: 7
